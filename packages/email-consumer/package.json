{
  "name": "@portaldots/email-consumer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:high": "wrangler dev --env high",
    "dev:normal": "wrangler dev --env normal",
    "deploy:high": "wrangler deploy --env high",
    "deploy:normal": "wrangler deploy --env normal",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "ci:check": "$npm_execpath run typecheck && $npm_execpath run lint && $npm_execpath run format:check",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply email-idempotency --local",
    "db:migrate:remote": "wrangler d1 migrations apply email-idempotency --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.43.0",
    "hono": "^4.12.14",
    "hono-email": "^0.3.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260424.1",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.0.0"
  }
}
