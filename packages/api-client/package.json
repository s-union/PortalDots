{
  "name": "@portaldots/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "typecheck:compat": "tsc --noEmit",
    "lint": "oxlint --type-aware .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci:check": "$npm_execpath run typecheck && $npm_execpath run lint && $npm_execpath run format:check",
    "codegen:api": "openapi-typescript ../../backend/api/openapi.yaml --output src/generated/schema.d.ts && oxfmt src/generated/schema.d.ts"
  },
  "dependencies": {
    "openapi-fetch": "0.17.0"
  },
  "devDependencies": {
    "@tanstack/vue-query": "5.101.0",
    "@typescript/native-preview": "7.0.0-dev.20260602.1",
    "openapi-typescript": "7.13.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "vue": "3.5.35"
  },
  "peerDependencies": {
    "@tanstack/vue-query": "5.101.0",
    "vue": "3.5.35"
  }
}
