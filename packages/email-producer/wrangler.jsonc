{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "email-producer",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-02",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "email-idempotency",
      "database_id": ""
    }
  ],
  "queues": {
    "producers": [
      {
        "queue": "email-high",
        "binding": "HIGH_QUEUE"
      },
      {
        "queue": "email-normal",
        "binding": "NORMAL_QUEUE"
      }
    ]
  }
}
