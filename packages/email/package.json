{
  "name": "@portaldots/email",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787 --inspector-port 9229",
    "dev:local-stack": "wrangler d1 migrations apply email-idempotency --local --persist-to .wrangler/state && wrangler dev --persist-to .wrangler/state --port 8787 --inspector-port 9229",
    "deploy": "wrangler deploy",
    "typecheck": "tsgo --noEmit",
    "typecheck:compat": "tsc --noEmit",
    "lint": "oxlint --type-aware .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "ci:check": "$npm_execpath run typecheck && $npm_execpath run lint && $npm_execpath run format:check",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "4.12.23",
    "hono-email": "0.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260604.1",
    "@typescript/native-preview": "7.0.0-dev.20260604.1",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "wrangler": "4.97.0"
  }
}
