{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Asia/Tokyo",
  "minimumReleaseAge": "3 days",
  "mode": "update",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "rangeStrategy": "pin",
  "pinDigests": true,
  "packageRules": [
    {
      "description": "Automerge all non-major updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Do not automerge mise updates",
      "matchManagers": ["mise"],
      "automerge": false
    },
    {
      "description": "Group non-major Tailwind packages",
      "matchPackageNames": ["tailwindcss", "tailwind-merge", "class-variance-authority", "/^@tailwindcss//"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Tailwind CSS Packages"
    },
    {
      "description": "Group non-major Vue ecosystem packages",
      "matchPackageNames": ["vue", "vue-router", "pinia", "@tanstack/vue-query", "/^@vue//"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Vue Ecosystem"
    },
    {
      "description": "Group non-major Development Tools",
      "matchPackageNames": ["oxlint", "oxfmt", "oxlint-tsgolint", "typescript", "vue-tsc", "vue-tsgo"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Frontend Development Tools"
    },
    {
      "description": "Keep Node.js type definitions aligned with the mise Node.js runtime",
      "matchPackageNames": ["@types/node"],
      "allowedVersions": "24.x",
      "groupName": "Node.js Runtime"
    },
    {
      "description": "Group non-major Storybook packages",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Storybook Ecosystem",
      "matchPackageNames": [
        "/^storybook/",
        "/^@storybook//"
      ]
    },
    {
      "description": "Group non-major Testing Tools",
      "matchPackageNames": ["jsdom", "msw", "msw-storybook-addon", "openapi-msw", "/^vitest/", "/^@vitest//", "/^@playwright//", "/^@vue/test-utils/"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Frontend Testing Tools"
    },
    {
      "description": "Group non-major Markdown parsing packages",
      "matchPackageNames": ["unified", "/^remark-/", "/^rehype-/"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Markdown Processing"
    },
    {
      "description": "Group non-major Cloudflare Worker runtime packages",
      "matchPackageNames": ["wrangler", "@cloudflare/workers-types"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Cloudflare Worker Runtime"
    },
    {
      "description": "Group non-major Hono packages",
      "matchPackageNames": ["hono", "hono-email"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Hono Ecosystem"
    },
    {
      "description": "Group non-major OpenAPI client packages",
      "matchPackageNames": ["openapi-fetch", "openapi-typescript"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "OpenAPI Client Packages"
    },
    {
      "description": "Keep zod aligned across workspaces (frontend + workers share a lockfile)",
      "matchPackageNames": ["zod"],
      "groupName": "zod"
    },
    {
      "description": "Group pnpm version updates across mise and packageManager",
      "matchManagers": ["mise", "npm"],
      "matchPackageNames": ["pnpm"],
      "groupName": "pnpm"
    },
    {
      "description": "Group non-major JavaScript Runtime (Node.js) in mise",
      "matchManagers": ["mise"],
      "matchPackageNames": ["node"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Node.js Runtime"
    },
    {
      "description": "Group non-major Go direct dependencies",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Go Backend Dependencies"
    },
    {
      "description": "Group non-major GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "GitHub Actions"
    }
  ]
}
