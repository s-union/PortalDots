{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "compilerOptions": {
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["vite/client", "node"]
    },
    "include": ["./typed-router.d.ts", "src/**/*.ts", "src/**/*.vue"],
    "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"]
}
