{
    "name": "@portaldots/frontend",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "typecheck": "tsgo --project tsconfig.node.json --noEmit && vue-tsgo --project tsconfig.app.json --noEmit",
        "typecheck:tsc": "tsc --project tsconfig.node.json --noEmit && vue-tsc --project tsconfig.app.json --noEmit",
        "lint": "oxlint --type-aware .",
        "format": "oxfmt .",
        "format:check": "oxfmt --check .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "ci:check": "$npm_execpath run typecheck && $npm_execpath run lint && $npm_execpath run format:check",
        "codegen:api": "openapi-typescript ../backend/api/openapi.yaml --output ../packages/api-client/src/generated/schema.d.ts",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@portaldots/api-client": "workspace:*",
        "@tanstack/vue-query": "^5.92.9",
        "pinia": "^3.0.4",
        "vue": "^3.5.30",
        "vue-router": "^5.0.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@storybook/addon-docs": "^10.2.19",
        "@storybook/vue3-vite": "^10.2.19",
        "@tailwindcss/vite": "^4.2.1",
        "@types/node": "^25.5.0",
        "@typescript/native-preview": "7.0.0-dev.20260314.1",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.9.0",
        "jsdom": "^28.1.0",
        "openapi-typescript": "^7.13.0",
        "oxfmt": "^0.40.0",
        "oxlint": "^1.55.0",
        "oxlint-tsgolint": "^0.16.0",
        "storybook": "^10.2.19",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.1.0",
        "vue-tsc": "^3.2.5",
        "vue-tsgo": "^0.1.1"
    }
}
