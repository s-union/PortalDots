{
  "name": "@portaldots/frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsgo --project tsconfig.node.json --noEmit && vue-tsgo --project tsconfig.app.json --noEmit",
    "typecheck:tsc": "tsc --project tsconfig.node.json --noEmit && vue-tsc --project tsconfig.app.json --noEmit",
    "lint": "oxlint --type-aware .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:storybook": "vitest run --project=storybook",
    "test:e2e": "playwright test",
    "ci:check": "$npm_execpath run typecheck && $npm_execpath run lint && $npm_execpath run format:check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@portaldots/api-client": "workspace:*",
    "@tanstack/vue-query": "^5.92.9",
    "class-variance-authority": "^0.7.1",
    "pinia": "^3.0.4",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.5.0",
    "temporal-polyfill-lite": "^0.3.3",
    "unified": "^11.0.5",
    "uqr": "^0.1.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/vue3-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^28.1.0",
    "msw": "^2.13.6",
    "msw-storybook-addon": "^2.0.7",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.5",
    "vue-tsgo": "^0.1.1"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
