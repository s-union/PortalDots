{
  "name": "@portaldots/frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsgo --project tsconfig.node.json --noEmit && golar typecheck",
    "typecheck:compat": "tsc --project tsconfig.node.json --noEmit && vue-tsc --project tsconfig.app.json --noEmit",
    "lint": "oxlint --type-aware .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:storybook": "vitest run --project=storybook",
    "test:e2e": "unset NO_COLOR; playwright test",
    "ci:check": "$npm_execpath run typecheck && $npm_execpath run lint && $npm_execpath run format:check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/vue-fontawesome": "3.2.0",
    "@portaldots/api-client": "workspace:0.0.0",
    "@tanstack/vue-query": "5.101.0",
    "class-variance-authority": "0.7.1",
    "pinia": "3.0.4",
    "rehype-sanitize": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "tailwind-merge": "3.6.0",
    "temporal-polyfill-lite": "0.4.0",
    "unified": "11.0.5",
    "uqr": "0.1.3",
    "vue": "3.5.35",
    "vue-router": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@golar/vue": "^0.1.7",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.4.2",
    "@storybook/addon-docs": "10.4.2",
    "@storybook/addon-vitest": "10.4.2",
    "@storybook/vue3-vite": "10.4.2",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "24.13.0",
    "@typescript/native-preview": "7.0.0-dev.20260605.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "golar": "^0.1.7",
    "jsdom": "29.1.1",
    "msw": "2.14.6",
    "msw-storybook-addon": "2.0.7",
    "openapi-msw": "2.0.0",
    "storybook": "10.4.2",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
