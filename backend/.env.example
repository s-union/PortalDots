PORTALDOTS_API_BIND=127.0.0.1:8080
PORTALDOTS_DATABASE_URL=postgres://portaldots:portaldots@127.0.0.1:55432/portaldots_rebuild?sslmode=disable
PORTALDOTS_ALLOW_DANGEROUSLY=true
PORTALDOTS_SYNC_AUTH_USER_ON_STARTUP=true
PORTALDOTS_STAFF_VERIFY_CODE=654321
PORTALDOTS_SESSION_COOKIE=portaldots_session
PORTALDOTS_SESSION_COOKIE_SECURE=false
APP_URL=http://127.0.0.1:5173
# メール送信に Cloudflare Workers を使う場合は以下を設定してください
# 未設定の場合はログ出力のみ行います
# PORTALDOTS_EMAIL_PRODUCER_URL=http://localhost:8787
# PORTALDOTS_EMAIL_PRODUCER_TOKEN=dev-token
