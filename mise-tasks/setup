#!/usr/bin/env bash
#MISE description="First-time setup: install tools, dependencies, hooks, .env, and init DB"

set -euo pipefail

mise install
[ -f .env ] || cp .env.example .env
[ -f packages/email/.dev.vars ] || cp packages/email/.dev.vars.example packages/email/.dev.vars
mise run frontend:install
prek install
mise run generate
mise run db:up
mise run db:wait
mise run backend:migrate
mise run backend:seed
mise run db:down
