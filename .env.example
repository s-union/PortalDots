# ────────────────────────────────────────
# PortalDots 設定
# 本番用: .env にコピーして編集
# ────────────────────────────────────────

PORTAL_APP_NAME=PortalDots
APP_URL=http://localhost:5173
PORTAL_DESCRIPTION=
PORTAL_ADMIN_NAME=〇〇実行委員会
PORTAL_CONTACT_EMAIL=info@example.com
PORTAL_UNIVEMAIL_DOMAIN_PART=ed.tus.ac.jp
PORTAL_STUDENT_ID_NAME=学籍番号
PORTAL_UNIVEMAIL_NAME=学校発行メールアドレス
PORTAL_VERSION=

# ── サーバー設定 ──
PORTAL_API_BIND=127.0.0.1:8080
PORTAL_DATABASE_URL=postgres://portaldots:portaldots@127.0.0.1:55432/portaldots_rebuild?sslmode=disable
PORTAL_DANGEROUSLY_ALLOW_DEMO_MODE=true
PORTAL_ENABLE_DEMO_MODE=false
PORTAL_MAINTENANCE_MODE=false
PORTAL_STAFF_VERIFY_CODE=654321
PORTAL_MIGRATIONS_DIR=db/migrations
PORTAL_REGISTRATION_VERIFY_TTL_MINUTES=60
PORTAL_RATE_LIMIT_PER_MINUTE=60

# ── セッション設定 ──
PORTAL_SESSION_COOKIE=portaldots_session
PORTAL_SESSION_COOKIE_SECURE=false
PORTAL_SESSION_TTL_SECONDS=86400

# ── メール送信 (Cloudflare Workers) ──
PORTAL_EMAIL_PRODUCER_URL=http://localhost:8787
PORTAL_EMAIL_PRODUCER_TOKEN=dev-token
PORTAL_SMTP_FROM=

# ── フロントエンド設定 ──
VITE_API_BASE_URL=/v1
VITE_API_PROXY_TARGET=http://127.0.0.1:8080
